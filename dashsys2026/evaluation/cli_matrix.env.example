# Copy to evaluation/cli_matrix.env or source before running run_cli_matrix.sh.
#
# By default, the matrix script runs all three model CLIs in their permissive
# "YOLO" modes. The prompt is sent on stdin unless your command contains the
# literal placeholder {prompt_file} or {prompt}.

# Enable/disable models.
RUN_CLAUDE=1
RUN_CODEX=1
RUN_GEMINI=1

# Default YOLO commands. Adjust only if your local CLI syntax differs.
CLAUDE_MODEL_CMD='/usr/local/bin/claude --dangerously-disable-osx-sandbox --dangerously-skip-permissions -p'
CODEX_MODEL_CMD='/usr/local/bin/codex --dangerously-disable-osx-sandbox exec --dangerously-bypass-approvals-and-sandbox -'
GEMINI_MODEL_CMD='/usr/local/bin/gemini --dangerously-disable-osx-sandbox --approval-mode=yolo -p ""'

# Main experiment settings.
DATASET=custom_analytics
CONFIGS='baseline best'
RELEVANT_SOURCE=heuristic

# Start with a smoke test, then remove LIMIT for the full run.
LIMIT=5

# Optional query/category filters.
# QUERY_IDS='AG-001,CJ-006,WF-010'
# CATEGORIES='Aggregation,Complex_JOINs'

# Generation-only by default. Set EXECUTE=1 once ClickHouse data and
# clickhouse-client are available.
EXECUTE=0
REPAIR_ON_ERROR=0
MAX_REPAIRS=1

# ClickHouse settings, used only when EXECUTE=1.
CLICKHOUSE_CLIENT=evaluation/bin/clickhouse-client
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=19000
CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=''

# Runtime settings.
MODEL_TIMEOUT_SEC=300
SQL_TIMEOUT_SEC=60
OVERWRITE=1

# Keep sequential by default to avoid rate limits and model-CLI session clashes.
PARALLEL=0
